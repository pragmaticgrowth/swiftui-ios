# build artifacts
swiftui-scan/.build/
*.swiftmodule

# huge regenerable data (rebuild with scripts/)
repos/
sg/
sg_std/
# pipeline intermediates are ignored, BUT the audit lint rules + orchestrator signals MUST ship
# (gitignore has no inline comments — keep these exceptions on their own lines)
*.tsv
!skills/*/lint/grep-tells.tsv
!scripts/audit-signals.tsv
# 92MB raw decl dump; not read by the CLI — regenerate via scripts/05_catalog.py
catalog/customComponents.json

# the plugin manifest dir must ship even though a global ~/.gitignore may hide dot-dirs
!.claude-plugin/

# eval: generated model outputs (seeds + RESULTS.md are committed)
eval/out/

# plugin settings (user-local, never committed)
.claude/*.local.md
.claude/*.local.json

# python / os
__pycache__/
*.pyc
.DS_Store

.agent-docs/

# universal binary produced by `make build-universal` (shipped via GitHub release, not committed)
/swiftui-ctx
